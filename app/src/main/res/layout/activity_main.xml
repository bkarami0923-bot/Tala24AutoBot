<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtTitle"
            android:text="Tala24 AutoBot"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtStatus"
            android:text="وضعیت: غیرفعال"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtToken"
            android:hint="Bot Token:"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtChatId"
            android:hint="Channel Name (@...):"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtInterval"
            android:hint="Auto Sending Interval (min):"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#222222"
            android:padding="10dp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:text="Save Settings"
            android:background="#FFD700"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSendOnce"
            android:text="Extract Prices and Send"
            android:background="#FFD700"
            android:textColor="#000000"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnStartAuto"
            android:text="Strat Auto Sending"
            android:background="#FFD700"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnStopAuto"
            android:text="Stop Auto Sending"
            android:background="#444444"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtLastMessage"
            android:text="Last Sent Message"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>
